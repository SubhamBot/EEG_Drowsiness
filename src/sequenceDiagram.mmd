sequenceDiagram
    participant PY as reader.py
    participant UART as USART1 RX (DMA)
    participant IDLE as uart_idle ISR
    participant PL as process_logic
    participant EEG as EegSensor
    participant SPD as SpeedSensor
    participant LOG as LogWriter (RTT)

    PY->>UART: E,alpha,beta\n / S,speed\n
    UART->>IDLE: IDLE line interrupt
    IDLE->>PL: spawn(packet)
    alt EEG packet
        PL->>EEG: parse_packet()
        EEG-->>PL: EegData { alpha, beta }
        PL->>PL: compute ratio, frame_limit, alert
        PL->>EEG: log(ratio, t_v, frame_limit, count, alert)
        EEG->>LOG: [EEG] ratio=.. alert=..
    else Speed packet
        PL->>SPD: parse_packet()
        SPD-->>PL: speed f32
        PL->>PL: update current_speed
        PL->>SPD: log(speed)
        SPD->>LOG: [SPEED] xx.x km/h
    end